# ========================================
# FlowSync 环境变量配置模板
# ========================================
# 使用方法：
#   1. 复制此文件并重命名为 .env
#   2. 将下方占位符替换为你的真实 API Key
#   3. .env 已被 .gitignore 排除，不会被提交到仓库
# ========================================

# 阿里云千问（DashScope）API Key
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your-api-key-here
