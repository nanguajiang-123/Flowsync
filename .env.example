# ========================================
# FlowSync 环境变量配置模板
# ========================================
# 使用方法：
#   1. 复制此文件并重命名为 .env
#   2. 将下方占位符替换为你的真实配置
#   3. .env 已被 .gitignore 排除，不会被提交到仓库
# ========================================

# 阿里云千问（DashScope）API Key
# 获取地址：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your-api-key-here

# ========================================
# JWT 鉴权配置
# ========================================
# JWT 签名密钥（至少 256 位，生产环境请使用随机字符串）
JWT_SECRET=your-jwt-secret-key-change-in-production
# Token 过期时间（秒），默认 86400 = 24 小时
JWT_EXPIRATION=86400
# 签名算法：HS256 / HS384 / HS512
JWT_ALGORITHM=HS256



MySQL_HOST=
MySQL_PORT=
MySQL_DATABASE=
MySQL_USERNAME=
MySQL_PASSWORD=
